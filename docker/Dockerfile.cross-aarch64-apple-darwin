# Cross-compilation image for aarch64-apple-darwin (macOS ARM64)
#
# Apple's SDK cannot be redistributed due to licensing, so it must be
# provided at build time. Build with:
#
#   1. Package the macOS SDK from Xcode:
#      See https://github.com/tpoechtrager/osxcross#packaging-the-sdk
#      Or download a pre-packaged tarball.
#
#   2a. Build with SDK URL:
#      docker build \
#        --build-arg MACOS_SDK_URL=<url_to_MacOSX.sdk.tar.xz> \
#        -t rsplayer-cross-aarch64-apple-darwin \
#        -f docker/Dockerfile.cross-aarch64-apple-darwin docker/
#
#   2b. Or build with local SDK file placed inside docker/:
#      docker build \
#        --build-arg MACOS_SDK_FILE=MacOSX14.4.sdk.tar.xz \
#        -t rsplayer-cross-aarch64-apple-darwin \
#        -f docker/Dockerfile.cross-aarch64-apple-darwin docker/
#
# Minimum macOS deployment target (cpal requires macOS 14+ for AudioHardwareDestroyProcessTap)
# SDK must be >= this version.

FROM ubuntu:22.04

ARG DEBIAN_FRONTEND=noninteractive

ARG MACOS_SDK_DIR="."
ARG MACOS_SDK_FILE="nonexistent"
ARG MACOS_SDK_URL="https://github.com/joseluisq/macosx-sdks/releases/download/15.0/MacOSX15.0.sdk.tar.xz"

# Base build dependencies
RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        curl \
        git \
        cmake \
        libxml2-dev \
        uuid-dev \
        libssl-dev \
        zlib1g-dev \
        libmpc-dev \
        libmpfr-dev \
        libgmp-dev \
        pkg-config \
        make \
        g++ \
        gcc \
        patch \
        xz-utils \
        bzip2 \
        python3 \
        ca-certificates \
        lsb-release \
        software-properties-common \
        gnupg \
    && rm -rf /var/lib/apt/lists/*

# Install LLVM/Clang 18 (osxcross requires modern Clang for macOS headers)
RUN curl https://apt.llvm.org/llvm.sh | bash -s -- 18 && \
    ln -sf /usr/bin/clang-18 /usr/bin/clang && \
    ln -sf /usr/bin/clang++-18 /usr/bin/clang++

# Clone osxcross
ARG OSXCROSS_COMMIT=aa4c5eac89df6ccaf2e28fbc6332ab6893047c3b
RUN git clone https://github.com/tpoechtrager/osxcross.git /opt/osxcross-src && \
    cd /opt/osxcross-src && \
    git fetch --depth=1 origin "${OSXCROSS_COMMIT}" && \
    git checkout "${OSXCROSS_COMMIT}" && \
    rm -rf /opt/osxcross-src/.git

# Copy the macOS SDK if provided as a local file
# The wildcard makes COPY a no-op when MACOS_SDK_FILE is the default "nonexistent"
COPY ${MACOS_SDK_DIR}/${MACOS_SDK_FILE}* /opt/osxcross-src/tarballs/

# Download the SDK from a URL if provided
RUN if [ -n "${MACOS_SDK_URL}" ]; then \
        cd /opt/osxcross-src/tarballs && \
        curl --retry 3 -L -o "$(basename "${MACOS_SDK_URL}")" "${MACOS_SDK_URL}"; \
    fi

# Validate SDK is present before building
RUN if [ "${MACOS_SDK_FILE}" = "nonexistent" ] && [ -z "${MACOS_SDK_URL}" ]; then \
        echo "ERROR: Must provide MACOS_SDK_FILE or MACOS_SDK_URL" >&2 && exit 1; \
    fi

# Build osxcross (the SDK tarball must already be in tarballs/)
RUN cd /opt/osxcross-src && \
    UNATTENDED=yes OSX_VERSION_MIN=14.0 TARGET_DIR=/opt/osxcross ./build.sh && \
    rm -rf /opt/osxcross-src/build /opt/osxcross-src/tarballs

# Extract the SDK version from the installed SDK directory and persist it.
# osxcross wrappers need OSXCROSS_SDK_VERSION to locate the SDK at runtime.
RUN SDK_DIR=$(ls -1d /opt/osxcross/SDK/MacOSX*.sdk | head -1) && \
    SDK_NAME=$(basename "$SDK_DIR") && \
    SDK_VER=$(echo "$SDK_NAME" | sed -E 's/MacOSX([0-9.]+)\.sdk/\1/') && \
    echo "Detected SDK: $SDK_NAME version=$SDK_VER" && \
    echo "$SDK_VER" > /opt/osxcross/SDK_VERSION && \
    TOOL_VER=$(ls /opt/osxcross/bin/aarch64-apple-darwin*-ar | \
                   sed 's|/opt/osxcross/bin/aarch64-apple-darwin||' | \
                   sed 's|-ar$||') && \
    echo "Detected osxcross tool version suffix: ${TOOL_VER}" && \
    ln -sf "aarch64-apple-darwin${TOOL_VER}-clang"    /opt/osxcross/bin/aarch64-apple-darwin-clang && \
    ln -sf "aarch64-apple-darwin${TOOL_VER}-clang++"  /opt/osxcross/bin/aarch64-apple-darwin-clang++ && \
    ln -sf "aarch64-apple-darwin${TOOL_VER}-ar"       /opt/osxcross/bin/aarch64-apple-darwin-ar && \
    ln -sf "aarch64-apple-darwin${TOOL_VER}-ld"       /opt/osxcross/bin/aarch64-apple-darwin-ld && \
    ln -sf "aarch64-apple-darwin${TOOL_VER}-nm"       /opt/osxcross/bin/aarch64-apple-darwin-nm && \
    ln -sf "aarch64-apple-darwin${TOOL_VER}-strip"    /opt/osxcross/bin/aarch64-apple-darwin-strip && \
    ln -sf "aarch64-apple-darwin${TOOL_VER}-ranlib"   /opt/osxcross/bin/aarch64-apple-darwin-ranlib && \
    ln -sf "aarch64-apple-darwin${TOOL_VER}-objdump"  /opt/osxcross/bin/aarch64-apple-darwin-objdump && \
    ln -sf "aarch64-apple-darwin${TOOL_VER}-pkg-config" /opt/osxcross/bin/aarch64-apple-darwin-pkg-config && \
    echo "${TOOL_VER}" > /opt/osxcross/TOOL_VERSION

# Determine the actual SDK directory name for CROSS_SYSROOT
RUN SDK_DIR=$(ls -1d /opt/osxcross/SDK/MacOSX*.sdk | head -1) && \
    echo "CROSS_SYSROOT=$SDK_DIR" && \
    echo "$SDK_DIR" > /opt/osxcross/SDK_PATH

COPY docker/darwin-entry.sh /darwin-entry.sh
RUN chmod +x /darwin-entry.sh

ENV PATH=/opt/osxcross/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

ENTRYPOINT ["/darwin-entry.sh"]
